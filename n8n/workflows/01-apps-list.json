    {
      "parameters": {
        "respondWith": "allIncomingItems",
        "options": {}
      },
      "id": "resp-apps-list",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [720, 300]
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Query Apps", "type": "main", "index": 0 }]] },
